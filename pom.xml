<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.example.spring.ai</groupId>
    <artifactId>ai-agent-java-sdk</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>AI Agent Java SDK</name>

    <modules>
        <module>ai-agent-java-sdk-core</module>
        <module>ai-agent-java-sdk-core/extensions/dynamodb-session-manager</module>
        <module>ai-agent-java-sdk-core/examples/quickstart-agent</module>
        <module>ai-agent-java-sdk-core/examples/calculator-minimal-agent</module>
        <module>ai-agent-java-sdk-core/examples/streaming-sse-agent</module>
        <module>ai-agent-java-sdk-core/examples/tool-discovery-filter-agent</module>
        <module>ai-agent-java-sdk-core/examples/minimal-agent</module>
        <module>ai-agent-java-sdk-core/examples/streaming-agent</module>
        <module>ai-agent-java-sdk-core/examples/tool-agent</module>
    </modules>

    <properties>
        <java.version>17</java.version>
        <spring-boot.version>3.5.9</spring-boot.version>
        <spring-ai.version>1.1.2</spring-ai.version>
        <maven.compiler.release>${java.version}</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring-boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>org.springframework.ai</groupId>
                <artifactId>spring-ai-bom</artifactId>
                <version>${spring-ai.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>
</project>
